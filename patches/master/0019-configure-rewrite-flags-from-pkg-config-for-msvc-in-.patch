From 9fd3daf511898718357a244cf83ff87534399d9f Mon Sep 17 00:00:00 2001
From: wang-bin <wbsecg1@gmail.com>
Date: Tue, 11 Jan 2022 16:17:56 +0800
Subject: [PATCH 19/35] configure: rewrite flags from pkg-config for msvc in
 msys

cflags and libs from pkg-config is unix path, e.g. /c/msys64, but msvc
requires mixed form, e.g. c:/msys64
---
 configure | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/configure b/configure
index d6ecf854e8..3743e61453 100755
--- a/configure
+++ b/configure
@@ -5215,8 +5215,8 @@ msvc_common_flags(){
             -libpath:*|-LIBPATH:*)echo $flag ;;
             -l*)                  echo ${flag#-l}.lib ;;
             -LARGEADDRESSAWARE)   echo $flag ;;
-            -L*) [ "$_flags_type" != "link" ] || echo -libpath:${flag#-L} ;;
-            -I*) [ "$_flags_type" = "link" ] || echo $flag ;;
+            -L*) [ "$_flags_type" != "link" ] || ([ -n "$MSYSTEM" ] && (echo $flag |sed 's,-L\/\([a-zA-Z]\)\(\/.*\),-libpath:\1:\2,' -) || echo -libpath:${flag#-L}) ;;
+            -I*) [ "$_flags_type" = "link" ] || ([ -n "$MSYSTEM" ] && (echo $flag |sed 's,-I\/\([a-zA-Z]\)\(\/.*\),-I\1:\2,' -) || echo $flag) ;;
             -D*) [ "$_flags_type" = "link" ] || echo $flag ;;
             -Wl,*)                ;;
             *)                    echo $flag ;;
-- 
2.53.0

